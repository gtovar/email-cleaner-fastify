{
  // Pragmatic starting point:
  // lint canonical repo docs, skip vendored/generated trees,
  // and enforce only a small subset that is useful today.
  "globs": [
    "**/*.md",
    "!.venv/**",
    "!python/**/venv/**",
    "!python/**/site-packages/**",
    "!**/dist/**",
    "!**/coverage/**",
    "!node_modules/**",
    "!.git/**"
  ],
  "config": {
    "MD013": false,
    "MD022": false,
    "MD024": false,
    "MD025": false,
    "MD026": false,
    "MD029": false,
    "MD031": false,
    "MD032": false,
    "MD034": false,
    "MD033": false,
    "MD040": false,
    "MD041": false,
    "MD060": false,
    "MD004": false
  }
}
